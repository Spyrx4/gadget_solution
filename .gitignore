# ============================================================
# GADGET SOLUTION — .gitignore (Release Version)
# Monorepo: Backend (NestJS) + AI Service (FastAPI) + Frontend (Next.js)
# ============================================================

# ─────────────────────────────────────────────
# Environment & Secrets (NEVER commit)
# ─────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
*.env
!.env.example

# ─────────────────────────────────────────────
# OS & Editor Generated
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/
*.code-workspace

# ─────────────────────────────────────────────
# Node.js / NestJS / Next.js (backend & frontend)
# ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json

# Build outputs
dist/
build/
.next/
out/
.turbo/
.vercel/
.netlify/

# TypeScript
*.tsbuildinfo

# Test & Coverage
coverage/
.nyc_output/

# ─────────────────────────────────────────────
# Python / FastAPI (ai-service)
# ─────────────────────────────────────────────
# Virtual environment
venv/
.venv/
env/
ENV/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
*.whl

# Pytest / Coverage
.pytest_cache/
htmlcov/
.coverage
.coverage.*

# Jupyter (if any notebooks exist)
.ipynb_checkpoints/

# ─────────────────────────────────────────────
# Database & Docker
# ─────────────────────────────────────────────
# Docker volumes (local data)
postgres_data/
pgdata/

# Prisma
backend/prisma/*.db
backend/prisma/*.db-journal

# ─────────────────────────────────────────────
# Logs & Temp
# ─────────────────────────────────────────────
logs/
*.log
tmp/
temp/

# ─────────────────────────────────────────────
# AI / ML Artifacts (large files)
# ─────────────────────────────────────────────
*.pkl
*.pickle
*.h5
*.hdf5
*.pt
*.pth
*.onnx
*.bin
*.safetensors
models/
checkpoints/
